// SpecFlow AI (Deal-Closer) — Prisma schema
// docs: https://pris.ly/d/prisma-schema
//
// SQLite 제약 메모:
//  - enum 미지원 → String + 앱 레벨 상수(src/lib/constants.ts)로 관리
//  - 배열/Json scalar 미지원 → 다중 값은 관계 테이블 또는 문자열(JSON/구분자) 직렬화
//  - 금액은 원(KRW) 단위 정수(Int)로 저장한다

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ========================= 조직 & 사용자 =========================

/// 팀/회사 단위. 모든 데이터의 최상위 소유자.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  invites         Invite[]
  documents       Document[]
  catalogItems    CatalogItem[]
  branding        Branding?
  creditWallet    CreditWallet?
  creditTxns      CreditTransaction[]
  emailTemplates  EmailTemplate[]
  teamMailDomains TeamMailDomain[]

  @@map("organizations")
}

/// 영업 담당자 / 리더 / 관리자
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("SALES_REP") // SALES_REP | LEADER | ADMIN
  avatarUrl String?
  signature String?  // 메일 서명 (발송 시 본문 하단에 추가)
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  // 선택한 팀 발신 도메인 (null = 개인 계정으로 발송). 도메인 삭제 시 개인 계정으로 자동 복귀.
  mailDomainId String?
  mailDomain   TeamMailDomain? @relation(fields: [mailDomainId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents     Document[]
  emailAccounts EmailAccount[]
  emailLogs     EmailLog[]
  generations   GenerationRequest[]
  emailTemplates EmailTemplate[] // 본인이 소유한 개인 메일 템플릿

  @@index([orgId])
  @@index([mailDomainId])
  @@map("users")
}

/// 팀원 초대 (관리자 콘솔 /team/members)
model Invite {
  id        String   @id @default(cuid())
  email     String
  role      String   @default("SALES_REP")
  status    String   @default("PENDING") // PENDING | ACCEPTED | EXPIRED
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([orgId])
  @@map("invites")
}

// ============================ 문서 ============================

/// 견적서/계약서/NDA/제안서 등 영업 문서
model Document {
  id          String   @id @default(cuid())
  title       String
  type        String   @default("QUOTE")  // QUOTE | CONTRACT | NDA | PROPOSAL
  status      String   @default("DRAFT")  // DRAFT | SENT | COMPLETED | VOID(폐기)
  clientName  String?                     // 거래처명
  amount      Int      @default(0)        // 총액(KRW 정수)
  currency    String   @default("KRW")
  contentJson String?                     // 에디터 본문(JSON 직렬화)
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items        DocumentItem[]
  emailLogs    EmailLog[]
  generation   GenerationRequest?
  referencedIn GenerationReference[] // 이 문서를 참고 자료로 사용한 생성 요청들

  @@index([orgId])
  @@index([authorId])
  @@index([status])
  @@map("documents")
}

/// 문서 라인 아이템 (견적 항목)
model DocumentItem {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Int      @default(1)
  unitPrice   Int      @default(0)
  amount      Int      @default(0)
  sortOrder   Int      @default(0)

  @@index([documentId])
  @@map("document_items")
}

// ==================== 카탈로그(마스터 데이터) ====================

/// 상품/서비스 카탈로그 (관리자 콘솔 /catalog)
model CatalogItem {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  category    String
  name        String
  sku         String?
  unit        String   @default("EA")
  unitPrice   Int      @default(0)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
  @@index([category])
  @@map("catalog_items")
}

// ====================== 메일 연동 & 발송 ======================

/// Gmail/Outlook 연동 계정 (/settings/email)
model EmailAccount {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String   // GMAIL | OUTLOOK
  email     String
  isDefault Boolean  @default(false)
  status    String   @default("CONNECTED") // CONNECTED | DISCONNECTED
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("email_accounts")
}

/// 팀(조직) 단위 발신 메일 도메인 — 관리자 콘솔(/settings/mail-domain)에서 등록·인증한다.
/// 담당자는 개인 연동 계정 대신 이 도메인 기반 주소(<핸들>@<domain>)로 발신하도록 선택할 수 있다.
/// - status: PENDING(인증 대기) → VERIFIED(인증됨, 데모는 관리자 수동 확인). VERIFIED 만 담당자가 선택 가능.
/// - isDefault: 팀 권장 발신 도메인(조직당 1개). 담당자 온보딩 시 안내에 사용.
model TeamMailDomain {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  domain    String   // 호스트명만 저장 (예: "specflow.ai", @ 제외)
  label     String?  // 표시용 별칭 (예: "회사 공식 도메인")
  status    String   @default("PENDING") // PENDING | VERIFIED
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]   // 이 도메인을 발신 도메인으로 선택한 담당자들

  @@unique([orgId, domain])
  @@index([orgId])
  @@map("team_mail_domains")
}

/// 이메일 발송 이력 (/sender/:documentId)
model EmailLog {
  id             String   @id @default(cuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User     @relation(fields: [senderId], references: [id])
  recipients     String   // 세미콜론(;) 구분 다중 수신자
  subject        String
  body           String?
  attachmentName String?
  status         String   @default("SENT") // SENT | FAILED
  sentAt         DateTime @default(now())

  @@index([documentId])
  @@map("email_logs")
}

/// 메일 발송 템플릿 (제목·본문 저장 → 발송 화면·관리 페이지에서 불러오기)
/// - ownerId 가 null 이면 팀 공용(조직 전체 공유), 값이 있으면 개인 전용이다.
/// - subject·body 의 {{거래처}}·{{문서제목}}·{{문서종류}}·{{총액}} 은 발송 시 현재 문서 값으로 치환한다.
model EmailTemplate {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownerId   String? // null = 팀 공용, 값 있으면 개인 소유자
  owner     User?        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  subject   String
  body      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([orgId])
  @@index([ownerId])
  @@map("email_templates")
}

// ======================= 크레딧 & 과금 =======================

/// 조직별 크레딧 잔액 (문서 생성 시 차감)
model CreditWallet {
  id        String   @id @default(cuid())
  orgId     String   @unique
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("credit_wallets")
}

/// 크레딧 충전/사용 내역 (관리자 콘솔 /billing)
model CreditTransaction {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  amount    Int      // +충전 / -사용
  type      String   // CHARGE | USAGE
  reason    String?
  createdAt DateTime @default(now())

  @@index([orgId])
  @@map("credit_transactions")
}

// ===================== AI 문서 생성 요청 =====================

/// AI 대화형 문서 생성 요청 (/generator)
model GenerationRequest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  prompt      String
  status      String    @default("PENDING") // PENDING | PROCESSING | DONE | FAILED
  creditsUsed Int       @default(0)
  documentId  String?   @unique
  document    Document? @relation(fields: [documentId], references: [id])
  createdAt   DateTime  @default(now())

  attachments Attachment[]
  references  GenerationReference[]

  @@index([userId])
  @@map("generation_requests")
}

/// AI 문서 생성 시 첨부한 원본 파일 (협력사 견적서 등)
/// - data: 원본 바이트(BLOB). 나중에 다운로드/열람 가능.
/// - extractedText: 엑셀/CSV 의 표 데이터를 텍스트로 추출한 값(있을 때만).
model Attachment {
  id            String   @id @default(cuid())
  generationId  String
  generation    GenerationRequest @relation(fields: [generationId], references: [id], onDelete: Cascade)
  fileName      String
  mimeType      String
  size          Int      // 바이트 단위 크기
  data          Bytes    // 원본 파일 바이트
  extractedText String?  // 엑셀/CSV 추출 텍스트 (PDF/이미지는 null)
  createdAt     DateTime @default(now())

  @@index([generationId])
  @@map("attachments")
}

/// AI 문서 생성 시 참고 자료로 가져온 보관함 문서 (기존 견적서 등)
/// GenerationRequest 와 기존 Document 를 잇는 조인 테이블.
model GenerationReference {
  id           String   @id @default(cuid())
  generationId String
  generation   GenerationRequest @relation(fields: [generationId], references: [id], onDelete: Cascade)
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([generationId, documentId])
  @@index([generationId])
  @@index([documentId])
  @@map("generation_references")
}

// ========================= 브랜딩 =========================

/// 조직 브랜딩 설정 (관리자 콘솔 /settings/branding)
model Branding {
  id           String   @id @default(cuid())
  orgId        String   @unique
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  companyName  String?
  logoUrl      String?
  primaryColor String   @default("#4F46E5")
  updatedAt    DateTime @updatedAt

  @@map("brandings")
}

// ================= 정책 (기획서 정책 라이브러리) =================

/// 기획서 정책 라이브러리 (24개 정책: AUTH_*, VAL_*, FORM_*, STATE_*, legal-* 등)
model Policy {
  id          String   @id @default(cuid())
  code        String   @unique
  scope       String   @default("project")
  description String
  createdAt   DateTime @default(now())

  @@map("policies")
}
